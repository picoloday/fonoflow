Options -MultiViews
RewriteEngine On

# 1. Primero: rutas /api/* → gateway CI4
RewriteRule ^api/ api/index.php [L,QSA]

# 1b. Rutas estáticas → servir directamente sin pasar por Vue
RewriteRule ^games/ - [L]
RewriteRule ^kairos/ - [L]

# 2. Archivos y directorios estáticos reales → servir tal cual
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Todo lo demás → SPA Vue (index.html)
RewriteRule ^ index.html [L]
