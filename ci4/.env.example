# Copia este archivo a .env y rellena los valores

CI_ENVIRONMENT = development

app.baseURL = 'http://fonoflow.test'

# Base de datos
database.default.hostname = 127.0.0.1
database.default.database = fonoflow
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port     = 3306

# Encriptación CI4 (genera una nueva con: php spark key:generate)
encryption.key = hex2bin:CAMBIA_ESTO

# API / JWT
cors.origin    = http://localhost:5173
api.username   = admin
api.password   = CAMBIA_ESTO
jwt.secret     = CAMBIA_ESTO_minimo_32_caracteres_aqui
